<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mecha - Asistente Virtual</title>
  
  <!-- Librería Moderna de Dialogflow (En GitHub corre nativa y perfecto) -->
  <script src="https://www.gstatic.com/dialogflow-console/fast/messenger/v1/messenger.js?v=1"></script>
  
  <style>
    html, body {
      margin: 0;
      padding: 0;
      background-color: #f4edf7; /* Fondo lila sutil de pantalla */
      font-family: 'Segoe UI', Arial, sans-serif;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* Caja contenedora del chat estilo App Móvil */
    .contenedor-mecha {
      width: 100%;
      max-width: 450px;
      height: 100vh;
      max-height: 680px;
      background-color: #ffffff;
      box-shadow: 0 12px 30px rgba(142, 68, 173, 0.15);
      position: relative;
      border-radius: 16px;
      overflow: hidden;
    }

    /* ESTILOS EXCLUSIVOS PARA MECHA: Sin textos pegados */
    df-messenger {
      --df-messenger-brand-color: #8E44AD;            /* Cabecera Morada */
      --df-messenger-font-color: #ffffff;             /* Texto blanco */
      --df-messenger-chat-background-color: #ffffff;   /* Fondo limpio */
      --df-messenger-user-message-background: #8E44AD; /* Tus burbujas moradas */
      --df-messenger-bot-message-background: #f0e6f5;  /* Respuestas de Mecha en lila suave */
      --df-messenger-button-title-backgound: #8E44AD;
      
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      height: 100%;
    }

    /* Adaptación total si lo abren desde un celular */
    @media (max-width: 480px) {
      .contenedor-mecha {
        max-width: 100%;
        max-height: 100vh;
        border-radius: 0;
      }
    }
  </style>
</head>
<body>

<div class="contenedor-mecha">
  <df-messenger
    intent="WELCOME"
    chat-title="Mecha"
    agent-id="e0dbe63b-3c93-40ad-9c32-efd39b5f4fc3"
    language-code="es"
    expand="true">
  </df-messenger>
</div>

</body>
</html>
