<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mecha - Asistente Virtual</title>
  
  <!-- TU SCRIPT EXACTO (El que destraba la pantalla en blanco) -->
  <script src="https://www.gstatic.com/dialogflow-console/fast/messenger/bootstrap.js?v=1"></script>
  
  <style>
    html, body {
      margin: 0;
      padding: 0;
      background-color: #f4edf7; /* Fondo lila sutil para la pantalla */
      font-family: 'Segoe UI', Arial, sans-serif;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* Caja contenedora estilo aplicación moderna */
    .contenedor-mecha {
      width: 100%;
      max-width: 480px; /* Ancho ideal para que se vea cómodo en PC y Notebooks */
      height: 90vh;
      max-height: 650px;
      background-color: #ffffff;
      box-shadow: 0 12px 30px rgba(142, 68, 173, 0.2);
      border-radius: 16px;
      overflow: hidden;
      position: relative;
    }

    /* Personalización estética de Mecha */
    df-messenger {
      --df-messenger-brand-color: #8E44AD;            /* Cabecera Morada Principal */
      --df-messenger-font-color: #ffffff;             /* Texto blanco de la cabecera */
      --df-messenger-chat-background-color: #ffffff;   /* Fondo del panel de chat */
      --df-messenger-user-message-background: #8E44AD; /* Tus burbujas de chat en morado */
      --df-messenger-bot-message-background: #f0e6f5;  /* Burbujas de Mecha en lila suave */
      
      /* Forzamos a que el elemento llene toda nuestra caja diseñada */
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      height: 100%;
    }

    /* Si lo abren desde un celular, se adapta por completo a la pantalla entera */
    @media (max-width: 480px) {
      .contenedor-mecha {
        max-width: 100%;
        max-height: 100vh;
        border-radius: 0;
      }
    }
  </style>
</head>
<body>

<div class="contenedor-mecha">
  <!-- Configuración de Mecha con saludo automático y ventana expandida -->
  <df-messenger
    intent="WELCOME"
    chat-title="Mecha"
    agent-id="e0dbe63b-3c93-40ad-9c32-efd39b5f4fc3"
    language-code="es"
    expand="true">
  </df-messenger>
</div>

</body>
</html>
